SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui
SECRET_KEY=uma-chave-secreta-aleatoria-longa

# SMTP — Zoho Mail (configurar apenas no servidor, nunca versionar com dados reais)
# Documentação: https://www.zoho.com/mail/help/zoho-smtp.html
# Porta 465 = SSL (recomendado) | Porta 587 = STARTTLS
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=jtasks.app@ativasys.com.br
# Se tiver 2FA ativado no Zoho, gere uma App Password em:
# https://accounts.zoho.com/home#security/app-password
SMTP_PASSWORD=sua_senha_ou_app_password
SMTP_FROM_NAME=Jtasks
